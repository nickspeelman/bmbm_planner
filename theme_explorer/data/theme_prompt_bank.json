{
  "version": "theme_prompt_bank_starting_point_followups_v2",
  "rendering": {
    "initial_screen": {
      "description": "Initial doors collect two responses: a short label first, then one concrete-detail answer.",
      "short_prompt_field": "short_prompt",
      "detail_prompts_field": "detail_prompts"
    },
    "follow_up_structure": [
      "Exploring",
      "{initial_door_label}: {initial_short_answer}",
      "Words so far: {selected_words_joined_by_dot}",
      "Use “{display}” as a starting point.",
      "What does “{display}” make you think of?"
    ],
    "follow_up_topic_template": "Use “{display}” as a starting point.",
    "follow_up_prompt_field": "prompt",
    "notes": [
      "The UI shows the starting point and selected words so far before the follow-up prompt.",
      "The selected vocabulary word is inserted into the starting-point line and the simple question.",
      "Do not select prompts by set type, grammar category, question_frame, part of speech, plurality, article, or any other vocabulary metadata.",
      "Every follow-up prompt must work after any word.",
      "The current implementation uses one universal follow-up prompt rather than rotating prompt types."
    ]
  },
  "language_rules": {
    "goal": "Ask for a plain next thought from the selected word. The UI carries the journey context; the prompt should not ask the client to interpret, explain meaning, or connect to earlier answers.",
    "must_work_after_examples": [
      "mirror",
      "soft",
      "becoming",
      "party",
      "protection",
      "blue",
      "mother",
      "threshold",
      "alone",
      "garden"
    ],
    "avoid_phrases": [
      "brings closer to the surface",
      "clearest detail",
      "comes up",
      "connection",
      "deep",
      "energy",
      "essence",
      "evoke",
      "hold next to",
      "how would you describe this",
      "inner",
      "journey",
      "meaning",
      "notice first",
      "original thought",
      "points back",
      "previous answer",
      "pulls forward",
      "reflect",
      "represent",
      "sit with",
      "symbolize",
      "tell me about a real example",
      "theme",
      "vibe",
      "what detail do you remember",
      "what do you remember",
      "what it means to you",
      "what it says about you",
      "what this word means",
      "what this word represents",
      "what this word symbolizes",
      "what would you tell Michele about this",
      "your first answer"
    ],
    "prefer_prompts_about": [
      "what the selected word makes someone think of",
      "plain associations rather than interpretation",
      "one sentence or clause answers"
    ]
  },
